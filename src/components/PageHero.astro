---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import heroImg from '../assets/Header pink colors (1).webp';

interface Props {
  title: string;
  eyebrow?: string;
}

const { title, eyebrow } = Astro.props;
const heroImage: ImageMetadata = heroImg;
---

<div class="relative w-full h-[60vh] md:h-[80vh] overflow-hidden rounded-[20px] md:rounded-[40px]">
  <Image
    src={heroImage}
    alt={title}
    class="absolute inset-0 w-full h-full object-cover"
    widths={[600, 1200, 1800]}
    sizes="100vw"
    loading="eager"
  />
  <div class="absolute inset-0 bg-black/20 pointer-events-none"></div>

  <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6">
    {eyebrow && <span class="meta text-white/80 uppercase">{eyebrow}</span>}
    <h1 class="mt-3 text-white">{title}</h1>
  </div>
</div>
