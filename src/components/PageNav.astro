---
import { HamburgerMenuOverlay } from '@/components/lightswind/HamburgerMenuOverlay';

const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const links = [
  { label: "Home", href: `${base}/` },
  { label: "About Me", href: `${base}/about` },
  { label: "Services", href: `${base}/services` },
  { label: "Destinations", href: `${base}/destinations` },
  { label: "Contact", href: `${base}/contact` },
  { label: "Instagram", href: "https://www.instagram.com/voyaflair", variant: "social" as const, iconType: "instagram" as const },
  { label: "Pinterest", href: "https://pinterest.com/voyaflair/", variant: "social" as const, iconType: "pinterest" as const },
  { label: "TikTok", href: "https://www.tiktok.com/@voyaflair", variant: "social" as const, iconType: "tiktok" as const },
];

const normalize = (p: string) => (p !== "/" ? p.replace(/\/$/, "") : p);
const isActive = (href: string) => normalize(pathname) === normalize(href);
---

<nav class="w-full text-gray-900 px-4 md:px-10" style="background-color: #ffffff;">
  <div class="max-w-[1500px] mx-auto flex items-center justify-between min-h-[61px] md:min-h-[129px] gap-4 md:gap-8">
    <a href={`${base}/`} class="text-xl font-bold tracking-wider" style="color: #69746E;">VF</a>

    <div class="hidden md:flex items-center gap-8 font-medium text-gray-600">
      {links.filter(link => link.variant !== 'social').map((link) => (
        <a
          href={link.href}
          class:list={[
            "hover:text-gray-900 transition-colors",
            isActive(link.href) && "text-gray-900 font-semibold",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="block md:hidden">
      <HamburgerMenuOverlay
        client:load
        items={links}
        buttonTop="18px"
        buttonRight="16px"
        buttonSize="md"
        buttonColor="transparent"
        iconColor="#191e23"
        overlayBackground="#F5F2EB"
        textColor="#111827"
        fontSize="lg"
        fontFamily='"Bodoni Moda", "Playfair Display", serif'
        fontWeight="normal"
        animationDuration={0.6}
        staggerDelay={0.05}
        menuAlignment="left"
        enableBlur={true}
        ariaLabel="Navigation menu"
      />
    </div>
  </div>
</nav>
