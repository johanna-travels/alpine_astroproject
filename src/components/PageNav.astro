---
const { pathname } = Astro.url;

const links = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Services", href: "/services" },
  { label: "Contact", href: "/contact" },
];
---

<nav class="relative z-50 w-full flex justify-between items-center py-4 px-4 md:py-6 md:px-10">
  <a href="/" class="text-xl md:text-2xl font-serif font-bold tracking-tight text-neutral-900">
    Voyaflair
  </a>

  <!-- Desktop links (md and up) -->
  <div class="hidden md:flex gap-10 meta text-neutral-600">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={[
          "uppercase transition-colors hover:text-neutral-900",
          pathname === link.href && "text-neutral-900",
        ]}
        aria-current={pathname === link.href ? "page" : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>

  <!-- Mobile trigger (below md) -->
  <button
    id="nav-open"
    aria-label="Open menu"
    class="md:hidden meta uppercase text-neutral-900"
  >
    Menu
  </button>
</nav>

<!-- Mobile full-screen menu -->
<div
  id="nav-menu"
  class="fixed inset-0 z-[60] hidden flex-col items-center justify-center gap-8 bg-white opacity-0 transition-opacity duration-300"
>
  <button
    id="nav-close"
    aria-label="Close menu"
    class="absolute top-6 right-6 text-4xl leading-none text-neutral-900 hover:text-neutral-500 transition-colors"
  >
    &times;
  </button>

  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        "nav-mobile-link font-serif text-4xl text-neutral-900",
        pathname === link.href && "italic",
      ]}
      aria-current={pathname === link.href ? "page" : undefined}
    >
      {link.label}
    </a>
  ))}
</div>

<script>
  const openBtn = document.getElementById('nav-open');
  const closeBtn = document.getElementById('nav-close');
  const menu = document.getElementById('nav-menu') as HTMLDivElement;
  const mobileLinks = document.querySelectorAll('.nav-mobile-link');

  const openMenu = () => {
    if (!menu) return;
    menu.classList.remove('hidden');
    menu.classList.add('flex');
    requestAnimationFrame(() => {
      menu.classList.remove('opacity-0');
      menu.classList.add('opacity-100');
    });
  };

  const closeMenu = () => {
    if (!menu) return;
    menu.classList.remove('opacity-100');
    menu.classList.add('opacity-0');
    setTimeout(() => {
      menu.classList.remove('flex');
      menu.classList.add('hidden');
    }, 300);
  };

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));
</script>
