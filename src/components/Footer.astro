---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="p-4 bg-[var(--color-white)]">
<header class="pt-16 pb-8 w-full bg-[#69746E] rounded-t-3xl">
    <div class="mx-auto w-full max-w-7xl px-6 sm:px-10">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-12 border-b border-white/10">
                <div class="flex flex-col gap-5">
                    <a href={`${base}/`} class="font-serif text-2xl tracking-wide" style=" color: white;">VF</a>
                    <p class="text-white/75 text-sm leading-relaxed">Voyaflair is a travel journal by Johanna.</p>
                </div>
                <div class="flex flex-col gap-5">
                    <h3 class="text-white/70 text-xs tracking-[0.3em] uppercase">Follow Me</h3>
                    <ul class="flex gap-6 items-center">
                        <li>
                            <a href="https://www.instagram.com/voyaflair?igsh=eTc2YnVldXlneHB2&amp;utm_source=qr" target="_blank" aria-label="Voyaflair on Instagram" class="flex items-center gap-2 text-white/80 hover:text-white transition-all duration-300 text-sm group">
