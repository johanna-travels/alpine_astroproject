                    </ul>
                </div>
                <div class="flex flex-col gap-5">
                    <h3 class="text-white/70 text-xs tracking-[0.3em] uppercase">Newsletter</h3>
                    <p class="text-white/75 text-sm leading-relaxed">Curated places, beautiful stays &amp; stories worth remembering — straight to your inbox.</p>
               <a 
                href="https://substack.com/" 
                target="_blank" 
                class="inline-block text-xs tracking-[0.2em] uppercase px-5 py-3 transition-all duration-300 w-fit hover:opacity-90 bg-[#F4F1EA] text-[#2D2D2D]"
                >
                Subscribe
                </a>
                </div>
            </div>
                <div class="pt-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                    <p class="text-white/70 text-xs">© 2026 Voyaflair — All rights reserved.</p>
                <ul class="flex flex-wrap gap-6 items-center">
                    <li><a href={`${base}/privacy-policy`} class="text-white/70 text-xs hover:text-white/80 transition-colors duration-300">Privacy Policy</a></li>
                    <li><a href={`${base}/cookie-policy`} class="text-white/70 text-xs hover:text-white/80 transition-colors duration-300">Cookie Policy</a></li>
                    <li><a href={`${base}/terms`} class="text-white/70 text-xs hover:text-white/80 transition-colors duration-300">Terms &amp; Conditions</a></li>
                    <li><a href={`${base}/Affilliate`} class="text-white/70 text-xs hover:text-white/80 transition-colors duration-300">Affiliate Disclosure</a></li>
                </ul>
            </div>
        </div>
    </header>
</footer>