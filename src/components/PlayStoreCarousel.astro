---
import { Image } from 'astro:assets';

// 1. Dynamic asset loading wrapper for local images
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif,webp}', { eager: true });

// 2. Uniform Data Structure for all items
const cards = [
  {
    category: "GREECE", 
    title: "Greece Vacation",
    desc: "Experience the pristine blue waters of the Aegean, historic ruins, and breathtaking Mediterranean sunsets.",
    src: "/src/assets/Article Kyoto.webp",
    alt: "Beautiful view of Greece",
    tagColor: "bg-blue-600 text-white",
    textColors: "text-blue-900 hover:bg-gray-200",
    imgWidth: 400,
    imgHeight: 600,
  },
  {
    category: "DEVELOPMENT",
    title: "UI Components",
    desc: "Beautifully crafted UI components that integrate seamlessly with your existing workflow and enhance user experience.",
    src: "/src/assets/Article Bali.webp",
    alt: "UI Design interface preview",
    tagColor: "bg-purple-600 text-white",
    textColors: "text-purple-900 hover:bg-gray-200",
    imgWidth: 400,
    imgHeight: 600,
  },
  {
    category: "OPTIMIZATION",
    title: "Performance",
    desc: "Optimized for speed and efficiency, ensuring your applications run smoothly even under heavy loads.",
    src: "/src/assets/Article Greece 1.webp",
    alt: "Performance optimization metrics dashboard",
    tagColor: "bg-green-600 text-white",
    textColors: "text-teal-900 hover:bg-gray-200",
    imgWidth: 400,
    imgHeight: 600,
  },
  {
    category: "SECURITY",
    title: "Security Layers",
    desc: "Advanced security features to protect your data and ensure privacy across all your applications and services.",
    src: "/src/assets/Article Bruges.webp",
    alt: "Secure cloud network vault encryption",
    tagColor: "bg-amber-600 text-white",
    textColors: "text-orange-900 hover:bg-gray-200",
    imgWidth: 400,
    imgHeight: 600,
  }
];
---

<div class="w-full max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-center text-gray-800 mb-8">Latest Articles</h1>

  <div class="relative overflow-hidden rounded-3xl p-4 sm:p-8">
    <div 
      id="carousel" 
      class="flex overflow-x-auto snap-x snap-mandatory gap-5 p-2 scroll-smooth [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      {cards.map((card) => (
        <div class="flex-none w-full sm:w-[calc(50%-10px)] lg:w-[calc(33.333%-14.2px)] h-[512px] rounded-3xl overflow-hidden relative group snap-start transition-all duration-300 hover:scale-[1.03] hover:shadow-2xl hover:shadow-black/50">
          
          {/* 3. The Unified Image Background Rendering Layer */}
          {images[card.src] ? (
            <Image 
              src={images[card.src].default} 
              alt={card.alt} 
              width={card.imgWidth}
              height={card.imgHeight}
              class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-300"
            />
          ) : (
            <div class="absolute inset-0 bg-slate-800" />
          )}

          {/* Vignette Shadow Overlay for Typography Readability */}
          <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-900/70 to-transparent z-0" />

          {/* Card Content Shell */}
          <div class="relative z-10 p-8 flex flex-col justify-between h-full">
            
            {/* Category Tag Line */}
            <div>
              
            </div>

            {/* Title, Body, and Button Action Block */}
            <div class="animate-[fadeInUp_0.6s_ease-out]">
              <h2 class="text-2xl font-bold text-white mb-3">{card.title}</h2>
              <p class="text-gray-300 text-sm sm:text-base mb-5 line-clamp-4 leading-relaxed">
                {card.desc}
              </p>
              <button class={`bg-white px-5 py-2.5 rounded-full text-sm font-semibold flex items-center gap-2 transition-all active:scale-95 ${card.textColors}`}>
                En savoir plus
                <span class="text-lg leading-none transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5">↗</span>
              </button>
            </div>

          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="flex justify-center mt-6 space-x-4">
    <button id="prevBtn" aria-label="previous" class="bg-white shadow-md border border-gray-200 p-2.5 rounded-full hover:bg-gray-50 active:scale-95 transition">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-gray-500"><path d="M5 12l14 0"></path><path d="M5 12l4 4"></path><path d="M5 12l4 -4"></path></svg>
    </button>
    <button id="nextBtn" aria-label="next" class="bg-white shadow-md border border-gray-200 p-2.5 rounded-full hover:bg-gray-50 active:scale-95 transition">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-gray-500"><path d="M5 12l14 0"></path><path d="M15 16l4 -4"></path><path d="M15 8l4 4"></path></svg>
    </button>
  </div>
</div>

<script>
  function initCarousel() {
    const carousel = document.getElementById('carousel') as HTMLDivElement;
    const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement;
    const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;
    
    if (!carousel || !prevBtn || !nextBtn) return;

    let scrollInterval: ReturnType<typeof setInterval>;

    function getScrollStep() {
      const firstCard = carousel.querySelector('.flex-none');
      return firstCard ? firstCard.clientWidth + 20 : 300;
    }

    function scrollToNext() {
      const cardWidth = getScrollStep();
      const maxScrollLeft = carousel.scrollWidth - carousel.clientWidth;
      
      if (carousel.scrollLeft >= maxScrollLeft - 5) {
        carousel.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        carousel.scrollBy({ left: cardWidth, behavior: 'smooth' });
      }
    }

    function scrollToPrevious() {
      const cardWidth = getScrollStep();
      
      if (carousel.scrollLeft <= 5) {
        carousel.scrollTo({ left: carousel.scrollWidth - carousel.clientWidth, behavior: 'smooth' });
      } else {
        carousel.scrollBy({ left: -cardWidth, behavior: 'smooth' });
      }
    }

    function handleAutoScroll() {
      scrollToNext();
    }

    function startAutoPlay() {
      scrollInterval = setInterval(handleAutoScroll, 3500);
    }

    function stopAutoPlay() {
      clearInterval(scrollInterval);
    }

    nextBtn.addEventListener('click', () => {
      scrollToNext();
    });

    prevBtn.addEventListener('click', () => {
      scrollToPrevious();
    });

    carousel.addEventListener('mouseenter', stopAutoPlay);
    carousel.addEventListener('mouseleave', startAutoPlay);
    carousel.addEventListener('touchstart', stopAutoPlay, { passive: true });
    carousel.addEventListener('touchend', startAutoPlay, { passive: true });

    startAutoPlay();
  }

  document.addEventListener('DOMContentLoaded', initCarousel);
</script>