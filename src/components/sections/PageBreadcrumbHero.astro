---
interface Props {
  title: string;
  currentPage: string;
  currentHref: string;
  imageSrc: string;
}

const { title, currentPage, currentHref, imageSrc } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const breadcrumbFont = "font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;";
---

<div class="page-breadcrumb-hero relative rounded-[30px] overflow-hidden mx-2 bg-scroll lg:bg-fixed" style={`background-image: url('${imageSrc}'); background-size: cover; background-position: center; min-height: 250px; height: 40vw; max-height: 500px;`}>
  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent pointer-events-none z-0"></div>
  <div class="relative z-10 w-full flex flex-col justify-end h-full">
    <div class="w-full max-w-[1300px] pl-4 pr-4 md:pl-10 md:pr-10 lg:pl-16 lg:pr-16 text-white pb-6 lg:pb-12">
      <h1 class="text-4xl md:text-6xl font-black tracking-tight mb-4" style={breadcrumbFont}>{title}</h1>
      <nav class="flex items-center gap-2 text-sm font-medium text-white/70">
        <a href={`${base}/`} class="hover:text-white transition-colors text-[0.875rem]" style={breadcrumbFont}>Home</a>
        <span class="text-white/50">/</span>
        <a href={currentHref} class="text-white hover:text-white/90 transition-colors text-[0.875rem]" style={breadcrumbFont}>{currentPage}</a>
      </nav>
    </div>
  </div>
</div>
