---
// FeatureSections.astro — alternating About/Services image+text sections (not a carousel)
import { Image } from 'astro:assets';
import aboutImg from '../assets/About me - medium 2option.webp';
import servicesImg from '../assets/services 4x3.webp';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const slides = [
  {
    title: "About Me",
    description: [
      "Hi, I'm Joanna.",
      "Originally from Greece and now based in Oslo, I created Voyaflair as a place to share destinations that stay with you long after the trip is over.",
      "What began as a way to share travel inspiration on Instagram soon grew into something more. I wanted a space where I could go beyond short captions and share the details, impressions, and experiences that help travellers connect more deeply with a destination.",
      "Through Voyaflair, I curate travel guides, thoughtful stays, local discoveries, and memorable experiences — all through my personal perspective and love for exploration."
    ],
    img: aboutImg,
    alt: "Architectural detail",
    btnText: "Read More →",
    href: `${base}/about`
  },
  {
    title: "Services",
    description: [
      "Voyaflair collaborates with hotels, tourism boards, and travel brands to create thoughtfully curated visual storytelling that captures the atmosphere, identity, and feeling of a destination  ",

      "Through a blend of photography, cinematic video, and editorial-style storytelling, each collaboration is designed to create content that feels both inspiring and intentional — with a focus on meaningful travel experiences, aesthetic detail, and emotional connection."
    ],
    img: servicesImg,
    alt: "Urban landscape",
    btnText: "Learn More →",
    href: `${base}/services`
  }
];
---

<div class="w-full bg-white text-neutral-900">
  {slides.map((slide, index) => {
    const isEven = index % 2 === 0;

    return (
      <section class="relative flex flex-col lg:flex-row w-full lg:items-stretch">
        
        <div class={`w-full lg:w-1/2 aspect-[4/3] lg:aspect-auto relative overflow-hidden group ${!isEven ? 'lg:order-last' : ''}`}>
          <Image 
            src={slide.img} 
            alt={slide.alt} 
            class="w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 group-hover:rotate-1" 
            loading="lazy"
            widths={[400, 800, 1200]}
            sizes="(max-width: 1024px) 100vw, 50vw"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-white/10 to-white/30 transition-opacity duration-500 group-hover:opacity-0 pointer-events-none"></div>
        </div>

        <div class={`w-full lg:w-1/2 flex items-center justify-center p-6 sm:p-8 lg:px-16 ${isEven ? 'bg-white' : 'bg-neutral-50'}`}>
          <div class="max-w-lg transition-transform duration-700 hover:-translate-y-2 py-8 sm:py-12 lg:py-16">
            
            
            <h2 class="mt-3 sm:mt-4 text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-bold leading-none bg-gradient-to-r from-neutral-900 to-neutral-600 bg-clip-text text-transparent">
              {slide.title}
            </h2>

            <!-- Changed this part -->
            <div class="mt-4 sm:mt-6 space-y-4 text-neutral-600 text-base sm:text-lg leading-relaxed">
              {slide.description.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>

            <a
              href={slide.href}
              class="inline-block mt-6 sm:mt-8 px-5 sm:px-6 py-2.5 sm:py-3 bg-neutral-900 text-white hover:bg-neutral-800 rounded-full text-xs sm:text-sm font-medium transition-all duration-300 hover:tracking-wider text-[0.875rem]"
              style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;"
            >
              {slide.btnText}
            </a>
          </div>
        </div>

      </section>
    );
  })}
</div>
