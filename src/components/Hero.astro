---
// src/components/Hero.astro
---

<style>
    body { font-family: 'Inter', sans-serif; }
     h1, h2, .font-serif {
            font-family: 'Playfair Display', serif;
        }
        .parallax-bg {
            will-change: transform;
        }
        .reveal {
            opacity: 0;
            transform: translateY(30px);
        }
        .custom-cursor {
            width: 20px;
            height: 20px;
            background: #1a1a1a;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9999;
            mix-blend-mode: difference;
            transition: transform 0.1s ease;
        }
        .nav-link::after {
            content: '';
            display: block;
            width: 0;
            height: 1px;
            background: #000;
            transition: width .3s;
        }
        .nav-link:hover::after {
            width: 100%;
        }
</style>

<div class="bg-white min-h-screen flex flex-col">

    <!-- Header Responsive -->
    <header class="w-full mx-auto flex justify-between items-center py-4 px-4 md:py-6 md:px-10">
        <div class="text-xl md:text-2xl font-bold tracking-tight text-gray-900">
            Linear
        </div>

        <nav class="hidden md:flex gap-10 text-gray-600 font-medium text-sm">
            <a href="#" class="hover:text-black transition">About</a>
            <a href="#" class="hover:text-black transition">Projects</a>
            <a href="#" class="hover:text-black transition">Pricing</a>
            <a href="#" class="hover:text-black transition">Blogs</a>
        </nav>

        <button class="bg-black text-white px-4 py-2 md:px-6 md:py-2.5 rounded-full text-xs md:text-sm font-semibold hover:bg-gray-800 transition">
            Book a call
        </button>
    </header>

