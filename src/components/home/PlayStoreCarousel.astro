---
import { Image } from 'astro:assets';
import CarouselDots from '@/components/carousel/CarouselDots.tsx';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 1. Dynamic asset loading wrapper for local images
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpeg,jpg,png,gif,webp}', { eager: true });

// 2. Uniform Data Structure for all items
const cards = [
  {
    category: "JAPAN",
    title: "Kyoto 5-Day Itinerary",
    href: `${base}/articles/kyoto-itinerary`,
    src: "/src/assets/articles/Article Kyoto.webp",
    alt: "Beautiful view of Greece",
    tagColor: "bg-blue-600 text-white",
    textColors: "text-blue-900 hover:bg-white",
    imgWidth: 400,
    imgHeight: 400,
  },
  {
    category: "BALI",
    title: "My Favorite Cafés in Bali",
    href: `${base}/articles/bali-cafes`,
    src: "/src/assets/articles/Article Bali.webp",
    alt: "UI Design interface preview",
    tagColor: "bg-purple-600 text-white",
    textColors: "text-purple-900 hover:bg-white",
    imgWidth: 400,
    imgHeight: 400,
  },
  {
    category: "GREECE",
    title: "Rhodes 5-Day Itinerary: Beaches, Day Trips & Best Local Food",
    href: `${base}/articles/rhodes-itinerary`,
    src: "/src/assets/articles/Article Greece.webp",
    alt: "Performance optimization metrics dashboard",
    tagColor: "bg-green-600 text-white",
    textColors: "text-teal-900 hover:bg-white",
    imgWidth: 400,
    imgHeight: 400,
  },
  {
    category: "BELGIUM",
    title: "Bruges Travel guide: Top Attractions and hidden gems",
    href: `${base}/articles/bruges-guide`,
    src: "/src/assets/articles/Article Bruges.webp",
    alt: "Secure cloud network vault encryption",
    tagColor: "bg-amber-600 text-white",
    textColors: "text-orange-900 hover:bg-white",
    imgWidth: 400,
    imgHeight: 400,
  }
];
---

<div class="carousel-container w-full">

  <!-- Outer Container (uid: 388) -->
<div class="flex flex-row flex-nowrap items-center pt-[30px] pb-[30px] gap-2 w-full lg:pt-[70px] lg:pl-[145px]">
  
  <!-- Heading Section (uid: 389) -->
  <div class="w-auto">
    <h2 class="text-[clamp(44px,9vw,75px)] font-normal leading-[0.9] text-black m-0 p-0 tracking-tight">
      Articles
    </h2>
  </div>

  <!-- Button Wrapper (uid: 390/1166) -->
  <div class="flex items-center">
    <a href={`${base}/destinations`} class="inline-block px-[32px] py-[5px] text-black text-[13px] font-medium  uppercase tracking-widest leading-none transition-all opacity-75 transition-opacity duration-300 hover:opacity-100">
      <span class="flex items-center">
        VIEW ALL 
        <span class="ml-2">→</span>
      </span>
    </a>
  </div>

</div>
  <!-- <h1 class="text-3xl font-bold text-center text-gray-800 mb-8">Latest Articles</h1> -->

  <div class="relative lg:ml-[120px] lg:mb-[50px]">
    <!-- Padding wrapper: spacing lives here so utility classes always apply -->
    <div class="pt-carousel-top-sm pb-dot-zone md:pt-carousel-top-md md:px-[40px] lg:pt-carousel-top-lg">
    <div id="carousel" class="scroll-wrapper">
      {cards.map((card) => (
        <a href={card.href} class="slide group block">
          {/* Image block */}
          <div class="slide-media relative">
            {images[card.src] ? (
              <Image
                src={images[card.src].default}
                alt={card.alt}
                width={card.imgWidth}
                height={card.imgHeight}
                densities={[1, 2]}
                class="slide-image absolute inset-0 transition-opacity duration-300"
              />
            ) : (
              <div class="absolute inset-0 bg-slate-800" />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent pointer-events-none z-10"></div>

            {/* Vignette Shadow Overlay */}
            {/* <div class="absolute inset-0 bg-gradient-to-r from-white/10 to-white/30 transition-opacity duration-500 group-hover:opacity-0 pointer-events-none" /> */}
          </div>

          {/* Text + link below the image */}
          <div class="pt-4 px-1 animate-[fadeInUp_0.6s_ease-out]">
            <span class="block text-[clamp(12px,1.5vw,14px)] font-normal text-black mb-1">{card.category}</span>
            <h2 class="text-[clamp(22px,5vw,30px)] font-extralight text-[#1e1e1e] leading-tight mb-2 group-hover:underline group-active:underline underline-offset-4 decoration-1">{card.title}</h2>
            <span class="text-[0.875rem] font-medium text-black inline-flex items-center gap-2 transition-all" style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">
              Read more
              <span class="leading-none transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
    </div>

    <CarouselDots client:visible carouselId="carousel" count={cards.length} gap={12} />
  </div>
</div>

<script>
  function initCarousel() {
    const carousel = document.getElementById('carousel') as HTMLDivElement;

    if (!carousel) return;

    let scrollInterval: ReturnType<typeof setInterval>;

    function getScrollStep() {
      const firstCard = carousel.querySelector('.slide');
      return firstCard ? firstCard.clientWidth + 12 : 300;
    }

    function scrollToNext() {
      const cardWidth = getScrollStep();
      const maxScrollLeft = carousel.scrollWidth - carousel.clientWidth;
      
      if (carousel.scrollLeft >= maxScrollLeft - 5) {
        carousel.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        carousel.scrollBy({ left: cardWidth, behavior: 'smooth' });
      }
    }

    function handleAutoScroll() {
      scrollToNext();
    }

    function startAutoPlay() {
      scrollInterval = setInterval(handleAutoScroll, 3500);
    }

    function stopAutoPlay() {
      clearInterval(scrollInterval);
    }

    carousel.addEventListener('mouseenter', stopAutoPlay);
    carousel.addEventListener('mouseleave', startAutoPlay);
    carousel.addEventListener('touchstart', stopAutoPlay, { passive: true });
    carousel.addEventListener('touchend', startAutoPlay, { passive: true });

    startAutoPlay();
  }

  document.addEventListener('DOMContentLoaded', initCarousel);

  function initZoom() {
    const carousel = document.getElementById('carousel');
    if (!carousel) return;

    const slides = carousel.querySelectorAll<HTMLElement>('.slide');
    if (!slides.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.intersectionRatio >= 0.3) {
            entry.target.classList.add('is-active');
          } else {
            entry.target.classList.remove('is-active');
          }
        });
      },
      { root: carousel, threshold: 0.3 }
    );

    slides.forEach((slide) => observer.observe(slide));
  }

  document.addEventListener('DOMContentLoaded', initZoom);
</script>

<style>
  .carousel-container {
    width: 100%;
    overflow: hidden; /* Clips the scrollbar if desired */
    padding: 10px; /* Section: 10px all sides -> 324px content on a 344px viewport */
    margin-bottom: 20px; /* Section: 20px bottom margin */
  }

  .scroll-wrapper {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory; /* The "Snap" behavior */
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    gap: 12px;
    scrollbar-width: none; /* Firefox; padding lives on the parent wrapper */
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  .scroll-wrapper::-webkit-scrollbar {
    display: none;
  }

  .slide {
    flex: 0 0 100%; /* Full mobile width (344px-style card); wrapper padding provides the peek */
    max-width: 100%;
    scroll-snap-align: center; /* Forces transition to stay center */
  }

  .slide-media {
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    width: 100%;
    max-width: 100%;
  }

  .slide-media :global(.slide-image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.08);
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .slide.is-active .slide-media :global(.slide-image) {
    transform: scale(1);
  }

  @media (min-width: 768px) {
    .slide {
      flex: 0 0 33.333%; /* Show 3 slides on desktop */
    }
  }
</style>