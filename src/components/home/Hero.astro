---
import { getImage } from 'astro:assets';
import heroImg from '@/assets/heroes/Header pink colors (1).webp';

const optimizedHero = await getImage({ src: heroImg, width: 1800, format: 'webp', quality: 75 });
---

<style>
    @keyframes heroFadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .hero-animate {
        animation: heroFadeIn 1.2s ease-out forwards;
    }

    /* Target the background specifically to avoid overriding Tailwind's layout classes */
    .hero-bg-logic {
        background-image: var(--bg-image);
        background-size: cover;
        background-repeat: no-repeat;
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        min-height: 100%;
        
    }

    @media (max-width: 480px) {
        .hero-bg-logic {
            min-height: 400px;
            background-position: 82% center; /* Focus on subjects for mobile portrait */
        }
    }

    @media (min-width: 481px) and (max-width: 768px) {
        .hero-bg-logic {
            min-height: 450px;
            background-position: center center;
        }
    }

    @media (min-width: 769px) and (max-width: 1024px) {
        .hero-bg-logic {
            min-height: 500px;
            background-position: center center;
        }
    }

    @media (min-width: 1025px) {
        .hero-bg-logic {
            min-height: 660px;
            background-attachment: fixed; /* Parallax effect for desktop */
        }
    }
</style>

<div class="w-full relative lg:h-[660px] md:h-[500px] sm:h-[450px] h-[400px]">
    <div
        class="hero-bg-logic hero-animate overflow-hidden rounded-[30px]"
        style={`--bg-image: url('${optimizedHero.src}');`}
    >
        {/* Semi-transparent overlay that covers the entire background */}
        <div class="absolute inset-0 bg-black/0.5 pointer-events-none z-0"></div>
        
        {/* Content */}
        <div class="relative z-10 h-full">
            <slot />
        </div>
    </div>
</div>