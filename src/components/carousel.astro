<script>
  const container = document.querySelector('.scroll-container') as HTMLElement;
  const sections = document.querySelectorAll('.scroll-section');
  const dots = document.querySelectorAll('.dot-nav');
  const actionButtons = document.querySelectorAll('.nav-trigger');
  
  let isScrolling = false;

  function scrollToSection(index: number) {
    if (!isScrolling && sections[index]) {
      isScrolling = true;
      sections[index].scrollIntoView({ behavior: 'smooth' });
      updateDots(index);
      setTimeout(() => {
        isScrolling = false;
      }, 1000);
    }
  }

  function updateDots(index: number) {
    dots.forEach((dot, i) => {
      if (i === index) {
        dot.className = 'dot-nav w-3 h-3 rounded-full transition-all duration-300 bg-neutral-900 scale-150';
      } else {
        dot.className = 'dot-nav w-3 h-3 rounded-full transition-all duration-300 bg-neutral-300 hover:bg-neutral-900 hover:scale-150';
      }
    });
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = parseInt(dot.getAttribute('data-index') || '0', 10);
      scrollToSection(index);
    });
  });

  actionButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const currentIndex = parseInt(btn.getAttribute('data-index') || '0', 10);
      if (currentIndex + 1 < sections.length) {
        scrollToSection(currentIndex + 1);
      }
    });
  });

  if (container) {
    container.addEventListener('scroll', () => {
      const index = Math.round(container.scrollTop / window.innerHeight);
      updateDots(index);
    });
  }

  updateDots(0);
</script> 
