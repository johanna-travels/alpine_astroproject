 ---
// Carousel.astro
const slides = [
  {
    num: "01",
    tag: "VISION",
    title: "Modern Architecture",
    description: "Exploring the intersection of form and function in contemporary design.",
    img: "https://images.unsplash.com/photo-1682687220742-aba13b6e50ba",
    alt: "Architectural detail",
    btnText: "Explore More →"
  },
  {
    num: "02",
    tag: "DESIGN",
    title: "Urban Spaces",
    description: "Creating environments that inspire and transform daily life.",
    img: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab",
    alt: "Urban landscape",
    btnText: "Learn More →"
  }
];
---

{/* Removed h-screen, snap-y, and overflow-y-auto to allow normal document scrolling */}
<div class="w-full bg-white text-neutral-900">
  
  {slides.map((slide, index) => {
    const isEven = index % 2 === 0;
    
    return (
      /* Changed min-h-screen to ensure sections fill the viewport nicely on desktop, but allow content to expand if needed */
      <section class="relative min-h-screen flex flex-col md:flex-row w-full">
        
        {/* Image Column */}
        {/* Adjusted height classes so it behaves nicely without strict h-screen boundaries */}
        <div class={`w-full md:w-1/2 h-[50vh] md:h-auto relative overflow-hidden group ${!isEven ? 'md:order-last' : ''}`}>
          <img 
            src={slide.img} 
            alt={slide.alt} 
            class="absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 group-hover:rotate-1" 
          />
          <div class={`absolute inset-0 bg-gradient-to-r ${isEven ? 'from-white/30 to-white/10' : 'from-white/10 to-white/30'} transition-opacity duration-500 group-hover:opacity-0`}></div>
        </div>

        {/* Content Column */}
        <div class={`w-full md:w-1/2 min-h-[50vh] md:min-h-screen flex items-center justify-center p-8 px-6 md:px-16 ${isEven ? 'bg-white' : 'bg-neutral-50'}`}>
          <div class="max-w-lg transition-transform duration-700 hover:-translate-y-2 py-12 md:py-0">
            <span class="text-neutral-500 tracking-wider text-sm font-mono">{slide.num} / {slide.tag}</span>
            <h2 class="mt-4 text-5xl md:text-7xl font-bold leading-none bg-gradient-to-r from-neutral-900 to-neutral-600 bg-clip-text text-transparent">
              {slide.title}
            </h2>
            <p class="mt-6 text-neutral-600 text-lg leading-relaxed">
              {slide.description}
            </p>
            <button 
              class="mt-8 px-6 py-3 bg-neutral-900 text-white hover:bg-neutral-800 rounded-full text-sm font-medium transition-all duration-300 hover:tracking-wider"
            >
              {slide.btnText}
            </button>
          </div>
        </div>

      </section>
    );
  })}
</div>
