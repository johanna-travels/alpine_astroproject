---
import PageHero from '../PageHero.astro';
---

<section class="relative w-full">
  <PageHero title="Destinations" eyebrow="Places worth knowing" />

  <div
    class="relative -mt-10 rounded-t-3xl px-4 md:px-10 pt-16 pb-24"
    style="background-color: var(--color-bg)"
  >
    <div class="mx-auto max-w-3xl text-center">
      <p class="prose-body text-neutral-700">
        Every destination here was chosen for a reason — not because it was trending,
        but because it left a mark.
      </p>
      <p class="prose-body text-neutral-700 mt-6">
        From quiet European towns to sun-soaked islands and hidden Asian temples,
        these are the places Voyaflair keeps coming back to.
      </p>
    </div>
  </div>
</section>
