---
import Layout from '@/layouts/Layout.astro';
import Footer from '@/components/layout/Footer.astro';
import PageNav from '@/components/layout/PageNav.astro';
import PageBreadcrumbHero from '@/components/sections/PageBreadcrumbHero.astro';
import { getImage } from 'astro:assets';
import articleImg from '@/assets/articles/Article Greece.webp';

const optimizedHeader = await getImage({ src: articleImg, width: 1800, format: 'webp', quality: 85 });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <PageNav />

  <PageBreadcrumbHero
    title="Rhodes 5-Day Itinerary"
    currentPage="Rhodes Itinerary"
    currentHref={`${base}/articles/rhodes-itinerary`}
    imageSrc={optimizedHeader.src}
  />

  <main class="w-full min-h-screen flex flex-col items-center py-16 bg-white">
    <article class="w-full max-w-[760px] px-4 md:px-0">
      <p class="text-[11px] uppercase tracking-[0.25em] text-neutral-500 font-sans mb-4">Greece</p>
      <h1 class="font-sans text-[36px] md:text-[48px] font-light text-neutral-900 leading-tight tracking-wide mb-8">
        Rhodes 5-Day Itinerary: Beaches, Day Trips & Best Local Food
      </h1>

      <p class="font-sans text-base md:text-[17px] text-neutral-600 font-normal italic border-l-2 border-neutral-200 pl-4 leading-relaxed mb-8">
        Five days on Rhodes, mixing the medieval old town with quiet beaches, island day trips and the kind of local tavernas that make Greek summers unforgettable.
      </p>

      <h2 class="font-sans text-[24px] md:text-[28px] font-light text-neutral-900 leading-tight tracking-wide mb-3">Day 1 — Rhodes Old Town</h2>
      <p class="font-sans text-[15px] md:text-[16px] text-neutral-700 font-normal leading-[1.85] mb-8">
        Begin in the medieval Old Town, one of the best-preserved in Europe. Wander the cobbled lanes within the city walls, visit the Palace of the Grand Master and stop for lunch in a quiet courtyard taverna away from the main streets.
      </p>

      <h2 class="font-sans text-[24px] md:text-[28px] font-light text-neutral-900 leading-tight tracking-wide mb-3">Day 2 — Lindos & the East Coast</h2>
      <p class="font-sans text-[15px] md:text-[16px] text-neutral-700 font-normal leading-[1.85] mb-8">
        Drive south to Lindos, with its whitewashed village and acropolis overlooking the bay. Spend the afternoon swimming at St. Paul's Bay before a slow dinner with views over the rooftops.
      </p>

      <h2 class="font-sans text-[24px] md:text-[28px] font-light text-neutral-900 leading-tight tracking-wide mb-3">Day 3 — Beaches & Hidden Coves</h2>
      <p class="font-sans text-[15px] md:text-[16px] text-neutral-700 font-normal leading-[1.85] mb-8">
        A slower day along the coast, hopping between Tsambika, Anthony Quinn Bay and quieter coves further from the resorts. Pack a picnic or settle in at a beachside taverna for fresh fish.
      </p>

      <h2 class="font-sans text-[24px] md:text-[28px] font-light text-neutral-900 leading-tight tracking-wide mb-3">Day 4 — Symi Day Trip</h2>
      <p class="font-sans text-[15px] md:text-[16px] text-neutral-700 font-normal leading-[1.85] mb-8">
        Take the ferry to the neighbouring island of Symi, famous for its colourful neoclassical harbour. A half-day is enough to explore the waterfront, climb to the old town and swim in clear water before heading back.
      </p>

      <h2 class="font-sans text-[24px] md:text-[28px] font-light text-neutral-900 leading-tight tracking-wide mb-3">Day 5 — Local Food & Slow Departure</h2>
      <p class="font-sans text-[15px] md:text-[16px] text-neutral-700 font-normal leading-[1.85] mb-10">
        Save the last day for food — a morning at the local market, a long lunch of meze and a final swim. Rhodes rewards an unhurried pace, and the best meals are usually the simplest ones.
      </p>

      <a href={`${base}/destinations`} class="inline-block text-black text-[13px] font-medium uppercase tracking-widest leading-none transition-all opacity-75 hover:opacity-100">
        <span class="flex items-center gap-2">← Back to Destinations</span>
      </a>
    </article>
  </main>

  <Footer />
</Layout>
