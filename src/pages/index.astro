---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import ContactSectionWithShader from '../block/contact-section-with-shader.tsx';
import Carousel from '../components/carousel.astro';
import AppleCardsCarouselDemo from '@/components/ui/apple-cards-carousel-demo.tsx';
import PlayStoreCarousel from '../components/PlayStoreCarousel.astro';
import GlobalEffects from '../components/GlobalEffects.astro';
import InfiniteText from '../block/infinite-text.tsx';
import PageNav from '../components/PageNav.astro';
import { getImage } from 'astro:assets';
import headerLightImg from '../assets/HeADER LIGHT.webp';

const optimizedHeader = await getImage({ src: headerLightImg, width: 1800, format: 'webp', quality: 85 });
---

<Layout>
    <GlobalEffects />
    <PageNav />

    <!-- HERO -->
    <div
      class="home-hero relative rounded-[30px] overflow-hidden bg-scroll lg:bg-fixed flex flex-col justify-end"
      style={`background-image: url('${optimizedHeader.src}'); margin-left: 8px; margin-right: 8px; margin-bottom: 0px;`}
    >
      <div class="absolute inset-0 bg-black/40 z-0"></div>
      <div class="relative z-10 flex items-center justify-center p-6 text-center text-white hero-inner" style="padding-left: 44px;">
        <div class="max-w-2xl">
          <h1 class="text-4xl md:text-6xl font-black tracking-tight mb-4">Discover Your Next Journey</h1>
          <p class="text-lg md:text-xl text-gray-200 font-light">Welcome to Voyaflair</p>
        </div>
      </div>
    </div>

    <!-- CONTENT -->
    <main class="text-slate-950" style="background-color: var(--color-bg)">
        <div class="flex flex-col gap-12 md:gap-20 pb-24 pt-12">
            <div class="reveal"><PlayStoreCarousel /></div>
            <div class="reveal"><InfiniteText client:visible /></div>
            <div class="reveal"><AppleCardsCarouselDemo client:visible /></div>
            <div class="reveal"><Carousel /></div>
            <ContactSectionWithShader client:load />
        </div>
    </main>

    <Footer />
</Layout>


<style>
  .home-hero {
    min-height: 250px;
    padding-top: 30px;
    padding-bottom: 30px;
    background-size: cover;
    background-position: center center;
  }
  @media (min-width: 768px) {
    .home-hero {
      min-height: 300px;
      padding-top: 40px;
      padding-bottom: 40px;
    }
  }
  @media (min-width: 1025px) {
    .home-hero {
      min-height: 740px;
      padding-top: 0;
      padding-bottom: 150px;
    }
  }
</style>