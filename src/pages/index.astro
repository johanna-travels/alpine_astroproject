---
import Layout from '@/layouts/Layout.astro';
import Footer from '@/components/layout/Footer.astro';
import ContactSectionWithShader from '@/components/sections/contact-section-with-shader.tsx';
import FeatureSections from '@/components/home/FeatureSections.astro';
import PlayStoreCarousel from '@/components/home/PlayStoreCarousel.astro';
import GlobalEffects from '@/components/home/GlobalEffects.astro';
import InfiniteText from '@/components/home/infinite-text.tsx';
import PageNav from '@/components/layout/PageNav.astro';
import { getImage } from 'astro:assets';
import headerLightImg from '@/assets/heroes/HeADER LIGHT.webp';
import baliImg from '@/assets/heroes/destination bali.webp';
import greeceImg from '@/assets/heroes/destination greece.webp';
import japanImg from '@/assets/heroes/destination japan.webp';
import belgiumImg from '@/assets/heroes/destination belgium.webp';
import { SeasonalHoverCards } from "@/components/lightswind/seasonal-hover-cards"


const optimizedHeader = await getImage({ src: headerLightImg, width: 1800, format: 'webp', quality: 75 });

const cardWidths = [320, 480, 640, 900];
const cardSizes = '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw';

async function buildSrcSet(img: ImageMetadata) {
  const variants = await Promise.all(
    cardWidths.map((w) => getImage({ src: img, width: w, format: 'webp', quality: 75 }))
  );
  return variants.map((v, i) => `${v.src} ${cardWidths[i]}w`).join(', ');
}

const baliSrcSet   = await buildSrcSet(baliImg);
const greeceSrcSet = await buildSrcSet(greeceImg);
const japanSrcSet  = await buildSrcSet(japanImg);
const belgiumSrcSet = await buildSrcSet(belgiumImg);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <Fragment slot="head">
    <link rel="preload" as="image" href={optimizedHeader.src} />
  </Fragment>
    <GlobalEffects />
    <PageNav />

    <!-- HERO: mobile & tablet only -->
    <div
      class="contact-hero relative rounded-[30px] overflow-hidden bg-scroll flex flex-col justify-end mx-2 block lg:hidden"
      style={`background-image: url('${optimizedHeader.src}'); background-size: cover; background-position: center; min-height: 300px; height: 50vw; max-height: 500px;`}
    >
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent pointer-events-none z-0"></div>

      <div class="relative z-10 w-full flex flex-col justify-end h-full">
        <div class="w-full max-w-[1300px] pl-4 pr-4 md:pl-10 md:pr-10 lg:pl-16 lg:pr-16 text-white pb-6 lg:pb-12">
          <p class="text-lg md:text-xl text-white/80 font-light">Welcome to Voyaflair</p>
          <div class="mt-4 flex items-center gap-5">
            <a href="https://www.instagram.com/voyaflair" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-white/70 hover:text-white transition-colors text-[0.875rem]" style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">
              <svg viewBox="0 0 448 512" width="20" height="20" fill="currentColor"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9-34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
            </a>
            <a href="https://pin.it/1z0Hoq3ct" target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="text-white/70 hover:text-white transition-colors text-[0.875rem]" style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">
              <svg viewBox="0 0 496 512" width="20" height="20" fill="currentColor"><path d="M496 256c0 137-111 248-248 248-25.6 0-50.2-3.9-73.4-11.1 10.1-16.5 25.2-43.5 30.8-65 3-11.6 15.4-59 15.4-59 8.1 15.4 31.7 28.5 56.8 28.5 74.8 0 128.7-68.8 128.7-154.3 0-81.9-66.9-143.2-152.9-143.2-107 0-163.9 71.8-163.9 150.1 0 36.4 19.4 81.7 50.3 96.1 4.7 2.2 7.2 1.2 8.3-3.3.8-3.4 5-20.3 6.9-28.1.6-2.5.3-4.7-1.7-7.1-10.1-12.5-18.3-35.3-18.3-56.6 0-54.7 41.4-107.6 112-107.6 60.9 0 103.6 41.5 103.6 100.9 0 67.1-33.9 113.6-78 113.6-24.3 0-42.6-20.1-36.7-44.8 7-29.5 20.5-61.3 20.5-82.6 0-19-10.2-34.9-31.4-34.9-24.9 0-44.9 25.7-44.9 60.2 0 22 7.4 36.8 7.4 36.8s-24.5 103.8-29 123.2c-5 21.4-3 51.6-.9 71.2C65.4 450.9 0 361.1 0 256 0 119 111 8 248 8s248 111 248 248z"/></svg>
            </a>
            <a href="https://www.tiktok.com/@voyaflair" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="text-white/70 hover:text-white transition-colors text-[0.875rem]" style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">
              <svg viewBox="0 0 448 512" width="20" height="20" fill="currentColor"><path d="M448,209.91a210.06,210.06,0,0,1-122.77-39.25V349.38A162.55,162.55,0,1,1,185,188.31V278.2a74.62,74.62,0,1,0,52.23,71.18V0l88,0a121.18,121.18,0,0,0 1.86,22.17h0A122.18,122.18,0,0,0,381,102.39a121.43,121.43,0,0,0,67,20.14Z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- HERO: desktop only -->
    <div
      class="contact-hero relative rounded-[30px] overflow-hidden hidden lg:flex flex-col justify-end mx-2 aspect-[21/9] max-h-[710px] bg-fixed"
      style={`background-image: url('${optimizedHeader.src}'); background-size: cover; background-position: center;`}
    >
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent pointer-events-none z-0"></div>

      <div class="relative z-10 w-full flex flex-col justify-end h-full">
        <div class="w-full max-w-[1300px] pl-4 pr-4 md:pl-10 md:pr-10 lg:pl-16 lg:pr-16 text-white pb-6 lg:pb-12">
          <h1 class="text-4xl md:text-6xl font-black tracking-tight mb-4" style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">Discover Your Next Journey</h1>
          <p class="text-lg md:text-xl text-white/80 font-light">Welcome to Voyaflair</p>
          <div class="flex flex-col items-center justify-center mt-8">
            <div class="flex flex-col items-center gap-2 cursor-pointer group animate-bounce">
              <svg class="w-10 h-10 text-white group-hover:text-white/80 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CONTENT -->
    <main class="text-slate-950 bg-white">
        <div class="flex flex-col gap-12 md:gap-20 pb-24 pt-12">
            <div class="reveal"><PlayStoreCarousel /></div>
            <div class="reveal py-16"><SeasonalHoverCards client:visible cards={[
              {
                title: "Bali",
                subtitle: "Indonesia",
                description: "Tropical paradise with stunning beaches and vibrant culture",
                imageSrc: baliImg.src,
                imageSrcSet: baliSrcSet,
                imageSizes: cardSizes,
                href: `${base}/bali`
              },
              {
                title: "Greece",
                subtitle: "Europe",
                description: "Ancient history meets crystal clear waters",
                imageSrc: greeceSrcSet.split(',')[0].split(' ')[0],
                imageSrcSet: greeceSrcSet,
                imageSizes: cardSizes,
                href: `${base}/greece`
              },
              {
                title: "Japan",
                subtitle: "Asia",
                description: "Where tradition meets modern innovation",
                imageSrc: japanImg.src,
                imageSrcSet: japanSrcSet,
                imageSizes: cardSizes,
                href: `${base}/japan`
              },
              {
                title: "Belgium",
                subtitle: "Europe",
                description: "Medieval charm and culinary delights",
                imageSrc: belgiumImg.src,
                imageSrcSet: belgiumSrcSet,
                imageSizes: cardSizes,
                href: `${base}/belgium`
              }
            ]} /></div>
            <div class="reveal"><InfiniteText client:visible /></div>
            <div class="reveal"><FeatureSections /></div>
            
            <ContactSectionWithShader client:idle base={base} />
        </div>
    </main>

    <Footer />
</Layout>

