---
import Layout from '@/layouts/Layout.astro';
import Footer from '@/components/layout/Footer.astro';
import PageNav from '@/components/layout/PageNav.astro';
---

<Layout>
  <PageNav />
  <main class="min-h-screen text-neutral-900 px-4 md:px-10 pb-24 pt-12" style="background-color: var(--color-bg)">
    <h1 class="text-[clamp(44px,9vw,75px)] font-normal leading-[0.9] text-black tracking-tight mb-8">
      Bali
    </h1>
    <p class="text-lg md:text-xl text-neutral-600 max-w-3xl">
      Bali moves between calm mornings, busy streets and quiet pockets of nature in a way that feels constant but never repetitive. My time there has been mostly centered around cafés, beaches and smaller local spots that shape how I experienced the island. This page gathers guides and travel notes from Bali.
    </p>
  </main>
  <Footer />
</Layout>
