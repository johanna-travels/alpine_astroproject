---
import Layout from '@/layouts/Layout.astro';
import Footer from '@/components/layout/Footer.astro';
import PageNav from '@/components/layout/PageNav.astro';
import { Image } from 'astro:assets';
import brugesArticleImg from '@/assets/articles/Article Bruges.webp';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <PageNav />
  <main class="min-h-screen text-neutral-900 px-4 md:px-10 pb-24 pt-12" style="background-color: var(--color-bg)">
    <h1 class="text-[clamp(44px,9vw,75px)] font-normal leading-[0.9] text-black tracking-tight mb-8">
      Belgium
    </h1>
    <p class="text-lg md:text-xl text-neutral-600 max-w-3xl">
      Explore the charm of Belgium — medieval cities, chocolate, and rich history.
    </p>

    <div class="relative lg:ml-[120px] lg:mb-[50px]">
      <div class="pt-8 pb-8 md:px-[40px]">
        <a href={`${base}/destinations`} class="slide group block">
          <div class="slide-media relative aspect-square w-full max-w-[400px] mx-auto overflow-hidden rounded-xl">
            <Image
              src={brugesArticleImg}
              alt="Bruges article"
              width={800}
              height={800}
              densities={[1, 2]}
              class="slide-image absolute inset-0 w-full h-full object-cover transition-opacity duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent pointer-events-none z-10"></div>
          </div>
          <div class="pt-4 px-1 max-w-[400px] mx-auto">
            <span class="block text-[clamp(12px,1.5vw,14px)] font-normal text-black mb-1">BELGIUM</span>
            <h4 class="text-[clamp(22px,5vw,30px)] font-extralight text-[#1e1e1e] leading-tight mb-2">Bruges Travel Guide</h4>
            <span class="text-[0.875rem] font-medium text-black inline-flex items-center gap-2 transition-all" style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">
              Read more
              <span class="leading-none transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5">→</span>
            </span>
          </div>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
