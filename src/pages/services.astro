---
import Layout from '@/layouts/Layout.astro';
import Footer from '@/components/layout/Footer.astro';
import PageNav from '@/components/layout/PageNav.astro';
import PageBreadcrumbHero from '@/components/sections/PageBreadcrumbHero.astro';
import { Image, getImage } from 'astro:assets';
import heroImg from '@/assets/heroes/services-img.webp';
import verticalImg from '@/assets/heroes/services vertical.webp';

const optimizedHeader = await getImage({ src: heroImg, width: 1800, format: 'webp', quality: 85 });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <PageNav />

  <PageBreadcrumbHero
    title="Services"
    currentPage="Services"
    currentHref={`${base}/services`}
    imageSrc={optimizedHeader.src}
  />

  <main class="text-neutral-900" style="background-color: var(--color-bg)">
    <div class="w-full py-[100px] px-0 bg-white">
      <div class="w-full max-w-[1300px] mx-auto px-4 xl:px-0 flex flex-col md:flex-row gap-y-[20px] md:gap-y-0 md:gap-x-[100px] items-center">
        <div class="w-full md:w-1/2 flex flex-col">
          <div class="overflow-hidden bg-neutral-100 aspect-[3/4] md:aspect-[4/5] lg:aspect-[3/4]">
            <Image
              class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
              src={verticalImg}
              alt="Services"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              widths={[480, 720, 900]}
              sizes="(min-width: 768px) 50vw, 100vw"
              format="webp"
              quality={85}
            />
          </div>
        </div>

        <article class="w-full md:w-1/2 flex flex-col gap-y-5">
          <div class="w-full md:w-20 h-[1px] bg-neutral-900 opacity-20 mb-2"></div>
          <p class="text-[10px] md:text-[11px] uppercase tracking-[0.25em] text-neutral-500 font-sans">LET'S CREATE SOMETHING BEAUTIFUL</p>
          <h2 class="font-sans text-[36px] md:text-[44px] font-light text-neutral-900 leading-tight tracking-wide">
            Work With Me
          </h2>
          <p class="font-sans text-base md:text-[17px] text-neutral-600 font-normal italic border-l-2 border-white pl-4 leading-relaxed">
            Voyaflair partners with hotels, tourism boards, travel brands, and hospitality businesses to create thoughtful visual content that captures the essence of a destination.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-neutral-700 font-normal leading-[1.85]">
            With a focus on atmosphere, design, and storytelling, each collaboration is crafted to highlight what makes a place memorable — from boutique hotels and unique stays to immersive travel experiences and local culture.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-neutral-700 font-normal leading-[1.85]">
            Through photography, video, and editorial-style content, I help brands connect with travelers in a way that feels authentic, inspiring, and visually engaging.
          </p>
          <div class="pt-4">
            <h3 class="font-sans text-[20px] md:text-[24px] font-light text-neutral-900 leading-tight tracking-wide mb-3">
              Social Media Collaboration
            </h3>
            <p class="font-sans text-[15px] md:text-[16px] text-neutral-600 font-normal leading-[1.85]">
              Authentic promotion across Instagram, TikTok, and other digital platforms through carefully curated content, including reels, stories, and posts designed to inspire travel and showcase destinations in a meaningful way.
            </p>
          </div>
          <div class="pt-2">
            <h3 class="font-sans text-[20px] md:text-[24px] font-light text-neutral-900 leading-tight tracking-wide mb-3">
              Content Creation
            </h3>
            <p class="font-sans text-[15px] md:text-[16px] text-neutral-600 font-normal leading-[1.85]">
              Professional photography and video content created for hotels, travel brands, and tourism campaigns. Designed to elevate your visual presence across websites, social media, marketing materials, and digital platforms.
            </p>
          </div>
        </article>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
