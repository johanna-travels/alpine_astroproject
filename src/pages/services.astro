---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import PageNav from '../components/PageNav.astro';
import ServicesSection from '../components/components/services.astro';
import { getImage } from 'astro:assets';
import heroImg from '../assets/services-img.webp';
import verticalImg from '../assets/services vertical.webp';

const optimizedHeader = await getImage({ src: heroImg, width: 1800, format: 'webp', quality: 85 });
const optimizedVertical = await getImage({ src: verticalImg, width: 900, format: 'webp', quality: 85 });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>

  <PageNav />

  <div
    class="services-hero relative rounded-[30px] overflow-hidden bg-scroll lg:bg-fixed flex flex-col justify-end mx-2"
    style={`background-image: url('${optimizedHeader.src}');`}
  >
    <div class="absolute inset-0 bg-black/0.5 pointer-events-none z-0"></div> 
    <div class="relative z-10 w-full flex flex-col justify-end h-[250px] md:h-[300px] lg:h-[592px]">
      <div class="w-full max-w-[1300px] pl-4 pr-4 md:pl-10 md:pr-10 lg:pl-16 lg:pr-16 text-white pb-6 lg:pb-12">
        <h1 class="text-4xl md:text-6xl font-black tracking-tight mb-4">Services</h1>
        <nav class="flex items-center gap-2 text-sm font-medium text-white/60">
          <a href={`${base}/`} class="hover:text-white/90 transition-colors text-[0.875rem]" style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">Home</a>
          <span class="text-white/40">/</span>
          <a href={`${base}/services`} class="text-white/90 hover:text-white transition-colors text-[0.875rem]" style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">Services</a>
        </nav>
      </div>
    </div>
  </div>

  <main class="text-neutral-900" style="background-color: var(--color-bg)">
     <main class="text-neutral-900">

    <div class="w-full py-[100px] px-0 bg-[#fcfcfc]">

      <div class="w-full max-w-[1300px] mx-auto px-4 xl:px-0 flex flex-col md:flex-row gap-y-[20px] md:gap-y-0 md:gap-x-[100px] items-center">

        <div class="w-full md:w-1/2 flex flex-col">
          <div class="overflow-hidden bg-[#f4f4f4] aspect-[3/4] md:aspect-[4/5] lg:aspect-[3/4]">
            <img
              class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
              src={optimizedVertical.src}
              alt="Profile"
              loading="lazy"
            />
          </div>

        </div>

        <article class="w-full md:w-1/2 flex flex-col gap-y-5">
          <div class="w-10 h-[1px] bg-[#111] opacity-20">LET'S CREATE SOMETHING BEAUTIFUL</div>
          <p class="text-[11px] uppercase tracking-[0.25em] text-[#999] font-sans"></p>
          <h2 class="font-serif text-[36px] md:text-[44px] font-light text-[#111] leading-tight tracking-wide">
            Work With Me
          </h2>
          <p class="font-sans text-base md:text-[17px] text-[#555] font-normal italic border-l-2 border-[#ddd] pl-4 leading-relaxed">
            Voyaflair partners with hotels, tourism boards, travel brands, and hospitality businesses to create thoughtful visual content that captures the essence of a destination.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-[#444] font-normal leading-[1.85]">
            With a focus on atmosphere, design, and storytelling, each collaboration is crafted to highlight what makes a place memorable — from boutique hotels and unique stays to immersive travel experiences and local culture.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-[#444] font-normal leading-[1.85]">
            Through photography, video, and editorial-style content, I help brands connect with travelers in a way that feels authentic, inspiring, and visually engaging.
          </p>
          <div class="pt-4">
            <h3 class="font-serif text-[20px] md:text-[24px] font-light text-[#111] leading-tight tracking-wide mb-3">
              Social Media Collaboration
            </h3>
            <p class="font-sans text-[15px] md:text-[16px] text-[#555] font-normal leading-[1.85]">
              Authentic promotion across Instagram, TikTok, and other digital platforms through carefully curated content, including reels, stories, and posts designed to inspire travel and showcase destinations in a meaningful way.
            </p>
          </div>
          <div class="pt-2">
            <h3 class="font-serif text-[20px] md:text-[24px] font-light text-[#111] leading-tight tracking-wide mb-3">
              Content Creation
            </h3>
            <p class="font-sans text-[15px] md:text-[16px] text-[#555] font-normal leading-[1.85]">
              Professional photography and video content created for hotels, travel brands, and tourism campaigns. Designed to elevate your visual presence across websites, social media, marketing materials, and digital platforms.
            </p>
          </div>
        </article>

      </div>
    </div>

  </main>
  </main>

  <Footer />

</Layout>

<style>
  .services-hero {
    background-size: cover;
    background-position: center center;
  }
</style>
