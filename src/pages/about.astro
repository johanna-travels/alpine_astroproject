---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import PageNav from '../components/PageNav.astro';
import AboutMe from '../components/components/aboutme.astro';
import { getImage } from 'astro:assets';
import heroImg from '../assets/about me-img.webp';
import verticalImg from '../assets/about me-vertical.webp';

const optimizedHeader = await getImage({ src: heroImg, width: 1800, format: 'webp', quality: 85 });
const optimizedVertical = await getImage({ src: verticalImg, width: 900, format: 'webp', quality: 85 });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <PageNav />

  <div
    class="about-hero relative rounded-[30px] overflow-hidden bg-scroll lg:bg-fixed flex flex-col justify-end mx-2"
    style={`background-image: url('${optimizedHeader.src}');`}
  >
    <div class="absolute inset-0 bg-black/40 z-0"></div>
    <div class="relative z-10 w-full flex flex-col justify-end h-[250px] md:h-[300px] lg:h-[592px]">
      <div class="w-full max-w-[1300px] pl-4 pr-4 md:pl-10 md:pr-10 lg:pl-16 lg:pr-4 text-white pb-6 lg:pb-12">
        <h1 class="text-4xl md:text-6xl font-black tracking-tight mb-4">About Me</h1>
        <nav class="flex items-center gap-2 text-sm font-medium text-white/60">
          <a href={`${base}/`} class="hover:text-white/90 transition-colors">Home</a>
          <span class="text-white/40">/</span>
          <a href={`${base}/about`} class="text-white/90 hover:text-white transition-colors">About Me</a>
        </nav>
      </div>
    </div>
  </div>

  <main class="text-neutral-900">

    <div class="w-full py-[100px] px-0 bg-[#fcfcfc]">

      <div class="w-full max-w-[1300px] mx-auto px-4 xl:px-0 flex flex-col md:flex-row gap-y-[20px] md:gap-y-0 md:gap-x-[100px] items-center">

        <div class="w-full md:w-1/2 flex flex-col">
          <div class="overflow-hidden bg-[#f4f4f4] aspect-[3/4] md:aspect-auto">
            <img
              class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
              src={optimizedVertical.src}
              alt="Profile"
              loading="lazy"
            />
          </div>
          
        </div>

        <article class="w-full md:w-1/2 flex flex-col gap-y-5">
          <div class="w-10 h-[1px] bg-[#111] opacity-20"></div>
          <p class="text-[11px] uppercase tracking-[0.25em] text-[#999] font-sans">About Me</p>
          <h2 class="font-serif text-[36px] md:text-[44px] font-light text-[#111] leading-tight tracking-wide">
            My Little Story
          </h2>
          <p class="font-sans text-base md:text-[17px] text-[#555] font-normal italic border-l-2 border-[#ddd] pl-4 leading-relaxed">
            Hi, I'm Joanna — originally from Greece and now based in Oslo. I created Voyaflair as a place to document and share destinations that stay with you long after the trip is over.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-[#444] font-normal leading-[1.85]">
            I first started sharing travel content on Instagram, but I quickly realised that some stories deserve more than a few seconds on a screen. While social media is a wonderful place for inspiration, it doesn't always leave room for the details, impressions, and practical insights that help travellers truly connect with a destination.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-[#444] font-normal leading-[1.85]">
            That's why I created Voyaflair — a space where I can go beyond short captions and share the places, experiences, and recommendations that I believe are genuinely worth remembering.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-[#555] font-normal leading-[1.85]">
            I'm drawn to destinations with character: thoughtfully designed hotels, memorable cafés, local food, hidden corners, and places that reveal something unique about the culture and identity of a destination.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-[#555] font-normal leading-[1.85]">
            For me, travel isn't about ticking off as many sights as possible. It's about experiencing a place through its atmosphere, details, and everyday moments — discovered while wandering through an unfamiliar street, stumbling upon a beautiful café, or finding a place you never planned to visit.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-[#555] font-normal leading-[1.85]">
            Through Voyaflair, I share curated destinations, thoughtful stays, travel guides, and experiences designed to help travellers explore more intentionally.
          </p>
          <p class="font-serif text-[15px] text-[#aaa] italic leading-relaxed pt-2 border-t border-[#eee]">
            Voyaflair is my personal travel journal — a collection of beautiful places, meaningful experiences, and destinations worth remembering.
          </p>
        </article>

      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .about-hero {
    background-size: cover;
    background-position: center center;
  }
</style>
