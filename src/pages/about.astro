---
import Layout from '@/layouts/Layout.astro';
import Footer from '@/components/layout/Footer.astro';
import PageNav from '@/components/layout/PageNav.astro';
import PageBreadcrumbHero from '@/components/sections/PageBreadcrumbHero.astro';
import { Image, getImage } from 'astro:assets';
import heroImg from '@/assets/heroes/about me-img.webp';
import verticalImg from '@/assets/heroes/about me-vertical.webp';

const optimizedHeader = await getImage({ src: heroImg, width: 1800, format: 'webp', quality: 75 });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <Fragment slot="head">
    <link rel="preload" as="image" href={optimizedHeader.src} />
  </Fragment>
  <PageNav />

  <PageBreadcrumbHero
    title="About Me"
    currentPage="About Me"
    currentHref={`${base}/about`}
    imageSrc={optimizedHeader.src}
  />

  <main class="text-neutral-900">
    <div class="w-full py-[100px] px-0 bg-white">
      <div class="w-full max-w-[1300px] mx-auto px-4 xl:px-0 flex flex-col md:flex-row gap-y-[20px] md:gap-y-0 md:gap-x-[100px] items-center">
        <div class="w-full md:w-1/2 flex flex-col">
          <div class="overflow-hidden bg-neutral-100 aspect-[3/4] md:aspect-auto">
            <Image
              class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
              src={verticalImg}
              alt="Profile"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              widths={[480, 720, 900]}
              sizes="(min-width: 768px) 50vw, 100vw"
              format="webp"
              quality={75}
            />
          </div>
        </div>

        <article class="w-full md:w-1/2 flex flex-col gap-y-5">
          <div class="w-10 h-[1px] bg-neutral-900 opacity-20"></div>
          <p class="text-[11px] uppercase tracking-[0.25em] text-neutral-500 font-sans">About Me</p>
          <h2 class="font-sans text-[36px] md:text-[44px] font-light text-neutral-900 leading-tight tracking-wide">
            My Little Story
          </h2>
          <p class="font-sans text-base md:text-[17px] text-neutral-600 font-normal italic border-l-2 border-white pl-4 leading-relaxed">
            Hi, I'm Joanna — originally from Greece and now based in Oslo. I created Voyaflair as a place to document and share destinations that stay with you long after the trip is over.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-neutral-700 font-normal leading-[1.85]">
            I first started sharing travel content on Instagram, but I quickly realised that some stories deserve more than a few seconds on a screen. While social media is a wonderful place for inspiration, it doesn't always leave room for the details, impressions, and practical insights that help travellers truly connect with a destination.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-neutral-700 font-normal leading-[1.85]">
            That's why I created Voyaflair — a space where I can go beyond short captions and share the places, experiences, and recommendations that I believe are genuinely worth remembering.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-neutral-600 font-normal leading-[1.85]">
            I'm drawn to destinations with character: thoughtfully designed hotels, memorable cafés, local food, hidden corners, and places that reveal something unique about the culture and identity of a destination.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-neutral-600 font-normal leading-[1.85]">
            For me, travel isn't about ticking off as many sights as possible. It's about experiencing a place through its atmosphere, details, and everyday moments — discovered while wandering through an unfamiliar street, stumbling upon a beautiful café, or finding a place you never planned to visit.
          </p>
          <p class="font-sans text-[15px] md:text-[16px] text-neutral-600 font-normal leading-[1.85]">
            Through Voyaflair, I share curated destinations, thoughtful stays, travel guides, and experiences designed to help travellers explore more intentionally.
          </p>
          <p class="font-sans text-[15px] text-neutral-400 italic leading-relaxed pt-2 border-t border-white">
            Voyaflair is my personal travel journal — a collection of beautiful places, meaningful experiences, and destinations worth remembering.
          </p>
        </article>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
