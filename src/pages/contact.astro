 ---
import Layout from "@/layouts/Layout.astro";
import PageNav from '../components/PageNav.astro';
import { getImage } from 'astro:assets';
import heroImg from '../assets/contac-img.webp';
import ContactSectionWithShader from '../block/contact-section-with-shader.tsx';
import Footer from '../components/Footer.astro';

const optimizedHeader = await getImage({ src: heroImg, width: 1800, format: 'webp', quality: 85 });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  
<PageNav />

<div
    class="services-hero relative rounded-[30px] overflow-hidden bg-scroll lg:bg-fixed flex flex-col justify-end mx-2"
    style={`background-image: url('${optimizedHeader.src}');`}
  >
    <div class="absolute inset-0 bg-black/0.5 pointer-events-none z-0"></div> 
    <div class="relative z-10 w-full flex flex-col justify-end h-[250px] md:h-[300px] lg:h-[592px]">
      <div class="w-full max-w-[1300px] pl-4 pr-4 md:pl-10 md:pr-10 lg:pl-16 lg:pr-16 text-white pb-6 lg:pb-12">
        <h1 class="text-4xl md:text-6xl font-black tracking-tight mb-4">Services</h1>
        <nav class="flex items-center gap-2 text-sm font-medium text-white/60">
          <a href={`${base}/`} class="hover:text-white/90 transition-colors text-[0.875rem]" style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">Home</a>
          <span class="text-white/40">/</span>
          <a href={`${base}/services`} class="text-white/90 hover:text-white transition-colors text-[0.875rem]" style="font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">Services</a>
        </nav>
      </div>
    </div>
  </div>

<ContactSectionWithShader client:idle showImage={false} className="mt-10 flex-center" />
<Footer />

</Layout>

<style>
  .contact-hero {
    background-size: cover;
    background-position: center center;
  }
</style>