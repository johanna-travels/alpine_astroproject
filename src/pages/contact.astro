---
import Layout from '@/layouts/Layout.astro';
import PageNav from '@/components/layout/PageNav.astro';
import PageBreadcrumbHero from '@/components/sections/PageBreadcrumbHero.astro';
import ContactSectionWithShader from '@/components/sections/contact-section-with-shader.tsx';
import Footer from '@/components/layout/Footer.astro';
import { getImage } from 'astro:assets';
import heroImg from '@/assets/heroes/contac-img.webp';

const optimizedHeader = await getImage({ src: heroImg, width: 1800, format: 'webp', quality: 75 });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <Fragment slot="head">
    <link rel="preload" as="image" href={optimizedHeader.src} />
  </Fragment>
  <PageNav />

  <PageBreadcrumbHero
    title="Contact"
    currentPage="Contact"
    currentHref={`${base}/contact`}
    imageSrc={optimizedHeader.src}
  />

  <ContactSectionWithShader client:load showImage={false} className="mt-10" base={base} />
  <Footer />
</Layout>
